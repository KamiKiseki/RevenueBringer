# Railway / Postgres — use the public DATABASE_URL for local dev (not *.railway.internal).
# Same variable for Flask (server.py) and Reflex Command Center (rxconfig imports models.DATABASE_URL).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

STRIPE_API_KEY=sk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Public storefront redirects only (no local/private URL leakage).
STRIPE_SUCCESS_URL=https://autoyieldsystems.com/success
STRIPE_CANCEL_URL=https://autoyieldsystems.com/pricing
# Stripe Price IDs for tiered checkout (optional; falls back to inline amounts).
STRIPE_PRICE_TRIAL_300=price_xxx
STRIPE_PRICE_MONTH_500=price_yyy
INSTANTLY_API_KEY=your_instantly_api_key
INSTANTLY_CAMPAIGN_ID=your_campaign_id
INSTANTLY_DOMAIN_WARMUP_ACTIVE=false
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
APIFY_API_TOKEN=your_apify_api_token
APIFY_GOOGLE_MAPS_ACTOR_ID=compass/crawler-google-places
OPENAI_API_KEY=your_openai_api_key

# New webhook + agreement automation settings.
VAPI_API_KEY=your_vapi_api_key
VAPI_CALL_WEBHOOK_URL=https://your-vapi-router.example.com/call
PANDADOC_API_KEY=your_pandadoc_api_key
PANDADOC_TEMPLATE_ID=VrZWq6WpiDVFMkh328wsb9
PANDADOC_SENDER_EMAIL=you@example.com

# Base URL shown in Command Center → Integrations (local Flask server.py).
WEBHOOK_BASE_URL=http://127.0.0.1:8000

# Value-first funnel (Hook -> tier pitch -> offer_selection -> PandaDoc -> Stripe).
VALUE_FIRST_FUNNEL=true
FREE_HOOK_LEAD_TARGET=2

# SMTP for real email sending + alerts + reports
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=app_password_here
SMTP_FROM_EMAIL=stevie@autoyieldsystems.com
REPORT_EMAIL_TO=you@example.com
REPLY_TO_EMAIL=stevie@autoyieldsystems.com

# Automation controls
AUTOMATION_INTERVAL_SECONDS=900
DAILY_REPORT_ENABLED=true
SIMULATE_MODE=true
OUTREACH_DAILY_CAP=50
VOICE_NOTIFICATION_MODE=true
SCHEDULER_TIMEZONE=US/Central
